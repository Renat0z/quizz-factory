{
  "name": "quizz-factory",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --port 5174\" \"node --env-file=.env server.js\"",
    "build": "vite build",
    "preview": "vite preview",
    "db:create": "node --env-file=.env db/createdb.js",
    "db:migrate": "node --env-file=.env db/migrate.js",
    "db:seed": "node --env-file=.env db/seed.js",
    "db:seed:desbravadores": "node --env-file=.env db/seed-desbravadores.js",
    "db:setup": "npm run db:create && npm run db:migrate && npm run db:seed",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "bcryptjs": "^2.4.3",
    "concurrently": "^9.1.0",
    "cors": "^2.8.5",
    "express": "^5.0.1",
    "groq-sdk": "^0.5.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.453.0",
    "postgres": "^3.4.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.0.2",
    "recharts": "^2.13.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.0.2",
    "msw": "^2.13.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "vite": "^5.4.11",
    "vitest": "^4.1.4"
  }
}
